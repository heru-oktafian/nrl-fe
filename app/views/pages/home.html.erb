<% 
# Set page title from API data
profile = @portfolio.dig('data', 'profile') || {}
skills = @portfolio.dig('data', 'skills') || []
tools = @portfolio.dig('data', 'tools') || []
social_links = @portfolio.dig('data', 'social_links') || []
projects = @portfolio.dig('data', 'projects') || []

content_for :title, "Portfolio - #{profile['name'] || 'Nurul DWI'}"
%>

<!-- ====== NAVBAR ====== -->
<nav class="fixed w-full top-0 left-0 z-[1000] bg-nrl-cream shadow-sm">
  <div class="max-w-6xl mx-auto px-5 lg:px-10 flex items-center justify-between py-[15px]">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-3 no-underline">
      <img src="/assets/images/logo.svg" alt="Logo" class="h-[55px] w-auto">
      <div class="flex items-center gap-[6px]">
        <span class="text-[1.6rem] font-bold text-nrl-dark">Nurul</span>
        <span class="text-[1.6rem] font-bold text-nrl-accent">Dwi</span>
      </div>
    </a>
    <!-- Desktop Nav Links -->
    <ul class="desktop-nav hidden md:flex items-center gap-[30px] list-none m-0 p-0">
      <li><a href="#beranda" class="text-nrl-dark font-semibold hover:text-nrl-accent transition-colors no-underline">Beranda</a></li>
      <li><a href="#tentang" class="text-nrl-dark font-semibold hover:text-nrl-accent transition-colors no-underline">Tentang</a></li>
      <li><a href="#keahlian" class="text-nrl-dark font-semibold hover:text-nrl-accent transition-colors no-underline">Keahlian</a></li>
      <li><a href="#portfolio" class="text-nrl-dark font-semibold hover:text-nrl-accent transition-colors no-underline">Portfolio</a></li>
      <li><a href="#kontak" class="text-nrl-dark font-semibold hover:text-nrl-accent transition-colors no-underline">Kontak</a></li>
    </ul>
    <!-- Mobile Hamburger Button -->
    <button type="button" data-mobile-nav-open class="mobile-nav-trigger md:hidden h-11 w-11 flex items-center justify-center rounded-full border border-nrl-text/20 text-nrl-dark transition hover:border-nrl-accent hover:text-nrl-accent" aria-label="Buka menu">
      <span class="text-2xl leading-none">☰</span>
    </button>
  </div>
</nav>

<!-- Mobile Navigation Overlay -->
<div data-mobile-nav-overlay class="fixed inset-0 z-[1010] hidden md:hidden">
  <div class="absolute inset-0 bg-nrl-dark/70"></div>
  <aside class="relative ml-auto flex h-full w-full max-w-sm flex-col bg-nrl-cream px-6 py-6 shadow-2xl">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <img src="/assets/images/logo.svg" alt="Logo" class="h-[55px] w-auto">
        <div class="flex items-center gap-[6px]">
          <span class="text-xl font-bold text-nrl-dark">Nurul</span>
          <span class="text-xl font-bold text-nrl-accent">Dwi</span>
        </div>
      </div>
      <button type="button" data-mobile-nav-close class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-nrl-text/20 text-nrl-dark transition hover:border-nrl-accent hover:text-nrl-accent" aria-label="Tutup menu">
        <span class="text-2xl leading-none">×</span>
      </button>
    </div>
    <nav class="mt-10 flex flex-col gap-5 text-base font-semibold text-nrl-dark">
      <a href="#beranda" class="rounded-xl px-3 py-3 transition hover:bg-nrl-light hover:text-nrl-accent no-underline">Beranda</a>
      <a href="#tentang" class="rounded-xl px-3 py-3 transition hover:bg-nrl-light hover:text-nrl-accent no-underline">Tentang</a>
      <a href="#keahlian" class="rounded-xl px-3 py-3 transition hover:bg-nrl-light hover:text-nrl-accent no-underline">Keahlian</a>
      <a href="#portfolio" class="rounded-xl px-3 py-3 transition hover:bg-nrl-light hover:text-nrl-accent no-underline">Portfolio</a>
      <a href="#kontak" class="rounded-xl px-3 py-3 transition hover:bg-nrl-light hover:text-nrl-accent no-underline">Kontak</a>
    </nav>
  </aside>
</div>

<!-- ====== HERO ====== -->
<section id="beranda" class="bg-nrl-brown text-nrl-cream pt-40 pb-[100px]">
  <div class="max-w-6xl mx-auto px-5 flex items-center gap-10">
    <!-- Left: Text -->
    <div class="flex-[1.1] fade-in">
      <h1 class="text-4xl lg:text-5xl font-bold leading-tight mb-6">
        Kreativitas Berbasis<br>Strategi:<br>
        <span class="text-nrl-cream/80"><%= profile['title'] || 'Senior UI/UX Designer & Visual Designer' %></span>
      </h1>
      <p class="text-nrl-cream/80 text-base leading-relaxed mb-8 max-w-lg">
        <%= profile['bio'] || "Saya seorang Senior UI/UX Designer dengan pengalaman bertahun-tahun menciptakan solusi digital yang berpusat pada manusia. Saya percaya desain yang baik adalah tentang menyelesaikan masalah melalui riset mendalam." %>
      </p>
      <!-- Buttons -->
      <div class="flex gap-[15px] mb-[25px]">
        <a href="#portfolio" class="inline-block bg-nrl-cream text-nrl-dark font-semibold px-7 py-3 rounded-full hover:bg-white transition-colors no-underline text-sm">Lihat Portfolio</a>
        <a href="#kontak" class="inline-block border-2 border-nrl-cream text-nrl-cream font-semibold px-7 py-3 rounded-full hover:bg-nrl-cream hover:text-nrl-dark transition-colors no-underline text-sm">Hubungi Saya</a>
      </div>
      <!-- Contact info -->
      <div class="flex items-center gap-[10px] text-nrl-cream/70 text-[0.9rem]">
        <img src="/assets/socials/ic-email.svg" alt="Email" class="w-4 h-4 opacity-70">
        <%= profile['email'] || 'nuruldwi@gmail.com' %>
      </div>
    </div>

    <!-- Right: Polaroid Image -->
    <div class="flex-1 text-right flex justify-end">
      <img src="/assets/hero/nurul-profile.png" alt="<%= profile['name'] || 'Nurul DWI' %> Profile"
           class="w-full max-w-[480px] rotate-[4deg] transition-all duration-500 ease-out border-[12px] border-white shadow-2xl cursor-pointer hover:rotate-0 hover:scale-105">
    </div>
  </div>
</section>

<!-- ====== ABOUT ====== -->
<section id="tentang" class="bg-nrl-light py-24 animate-on-scroll">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-16">
      <h2 class="text-3xl lg:text-4xl font-bold text-nrl-dark mb-4">
        Tentang <span class="text-nrl-accent">Saya</span>
      </h2>
      <p class="text-nrl-text/70 font-medium max-w-2xl mx-auto leading-relaxed">
        Fokus utama saya adalah membantu startup dan perusahaan teknologi membangun produk yang tidak hanya fungsional, tetapi juga memberikan kesan emosional yang kuat bagi penggunanya.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Card 1 -->
      <div class="group bg-white rounded-xl border border-nrl-text/10 p-7 shadow-sm hover:-translate-y-2 hover:shadow-xl transition-all duration-300 cursor-pointer">
        <div class="mb-5 transition-transform duration-300 group-hover:scale-110">
          <img src="/assets/services/riset-logo.svg" alt="Riset" class="w-12 h-12">
        </div>
        <h3 class="text-lg font-bold text-nrl-dark mb-3 transition-colors duration-300 group-hover:text-nrl-accent">Riset & Strategi</h3>
        <p class="text-nrl-text/70 text-sm leading-relaxed">
          Membangun fondasi desain yang kuat melalui user interview dan persona development guna menjawab kebutuhan nyata.
        </p>
      </div>
      <!-- Card 2 -->
      <div class="group bg-white rounded-xl border border-nrl-text/10 p-7 shadow-sm hover:-translate-y-2 hover:shadow-xl transition-all duration-300 cursor-pointer">
        <div class="mb-5 transition-transform duration-300 group-hover:scale-110">
          <img src="/assets/services/arsitektur-logo.svg" alt="Arsitektur" class="w-12 h-12">
        </div>
        <h3 class="text-lg font-bold text-nrl-dark mb-3 transition-colors duration-300 group-hover:text-nrl-accent">Arsitektur & Struktur</h3>
        <p class="text-nrl-text/70 text-sm leading-relaxed">
          Merancang alur informasi yang logis melalui wireframing dan user flows memastikan navigasi bebas hambatan.
        </p>
      </div>
      <!-- Card 3 -->
      <div class="group bg-white rounded-xl border border-nrl-text/10 p-7 shadow-sm hover:-translate-y-2 hover:shadow-xl transition-all duration-300 cursor-pointer">
        <div class="mb-5 transition-transform duration-300 group-hover:scale-110">
          <img src="/assets/services/visual-logo.svg" alt="Visual" class="w-12 h-12">
        </div>
        <h3 class="text-lg font-bold text-nrl-dark mb-3 transition-colors duration-300 group-hover:text-nrl-accent">Visual & Sistem</h3>
        <p class="text-nrl-text/70 text-sm leading-relaxed">
          Menciptakan identitas visual konsisten menggunakan design systems dan tipografi untuk memperkuat estetika.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ====== SKILLS ====== -->
<section id="keahlian" class="bg-white py-24 animate-on-scroll">
  <div class="max-w-6xl mx-auto px-5 flex flex-col lg:flex-row items-center gap-16">
    <!-- Left illustration -->
    <div class="flex-shrink-0">
      <img src="/assets/images/skills.svg" alt="Ilustrasi Keahlian" class="w-72 lg:w-80">
    </div>
    <!-- Right content -->
    <div class="flex-1">
      <h2 class="text-3xl lg:text-4xl font-bold text-nrl-dark mb-2">
        Keahlian <span class="text-nrl-accent">Teknis</span>
      </h2>
      <p class="text-nrl-text/70 font-medium mb-8">Teknologi dan framework yang saya kuasai</p>

      <!-- Progress bars - Dynamic from API -->
      <div class="space-y-5 mb-10">
        <% skills.each_with_index do |skill, index| %>
        <div>
          <div class="flex justify-between mb-2">
            <span class="text-sm font-medium text-nrl-text"><%= skill['name'] %></span>
            <span class="text-sm font-semibold text-nrl-accent"><%= skill['level'] %>%</span>
          </div>
          <div class="w-full bg-nrl-light rounded-full h-2">
            <div class="skill-bar-fill skill-<%= index %> bg-nrl-accent h-2 rounded-full" style="--target-width: <%= skill['level'] %>%"></div>
          </div>
        </div>
        <% end %>
      </div>

      <!-- Tools - Dynamic from API -->
      <h3 class="text-lg font-bold text-nrl-dark mb-4">Tools & Technologies</h3>
      <div class="grid grid-cols-3 sm:grid-cols-5 gap-4">
        <% tools.each do |tool| %>
        <div class="group cursor-pointer flex flex-col items-center gap-2 bg-nrl-light rounded-xl p-4 hover:-translate-y-2 hover:shadow-xl transition-all duration-300">
          <div class="transition-transform duration-300 group-hover:scale-110">
            <img src="https://cdn.simpleicons.org/<%= tool['icon'] %>" alt="<%= tool['name'] %>" class="w-7 h-7" loading="lazy" onerror="this.onerror=null; this.src='/assets/tools/default.svg';">
          </div>
          <span class="text-xs font-medium text-nrl-text text-center transition-colors duration-300 group-hover:text-nrl-accent"><%= tool['name'] %></span>
        </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- ====== PORTFOLIO ====== -->
<section id="portfolio" class="bg-nrl-accent py-24 animate-on-scroll">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-16">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-3">Portfolio Saya</h2>
      <p class="text-white/80 font-medium">Ada beberapa project terbaik yang saya kerjakan</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <% projects.each do |project| %>
      <div class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 cursor-pointer">
        <img src="<%= project['image_url'] || '/assets/portfolio/default.png' %>" alt="<%= project['title'] %>" class="w-full">
        <div class="p-6">
          <h3 class="text-lg font-bold text-nrl-dark mb-2 transition-colors duration-300 group-hover:text-nrl-accent"><%= project['title'] %></h3>
          <p class="text-nrl-text/70 text-sm leading-relaxed"><%= project['description'] %></p>
        </div>
      </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ====== KONTAK & KOLABORASI ====== -->
<section id="kontak" class="contact animate-on-scroll">
  <div class="max-w-[950px] mx-auto px-5">
    <!-- Section Title -->
    <h2 class="contact-main-title">Mari Berkolaborasi</h2>

    <!-- Contact Box -->
    <div class="contact-box">
      <!-- Left: Info -->
      <div class="contact-info">
        <h3>Hubungi Saya</h3>

        <!-- Email -->
        <div class="info-item">
          <svg class="contact-icon" viewBox="0 0 24 24">
            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
          <div>
            <strong>Email</strong>
            <p><%= profile['email'] || 'nuruldwi@gmail.com' %></p>
          </div>
        </div>

        <!-- WhatsApp -->
        <div class="info-item">
          <svg class="contact-icon" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          </svg>
          <div>
            <strong>WhatsApp</strong>
            <p>+62 812-3456-7890</p>
          </div>
        </div>

        <!-- Location -->
        <div class="info-item">
          <svg class="contact-icon" viewBox="0 0 24 24">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          <div>
            <strong>Lokasi</strong>
            <p><%= profile['location'] || 'Jakarta, Indonesia' %></p>
          </div>
        </div>

        <!-- Follow Saya -->
        <h4 class="follow-title">Follow Saya:</h4>
        <ul class="social-links">
          <% social_links.each do |link| %>
          <li>
            <svg class="social-icon" viewBox="0 0 24 24">
              <% case link['platform'].downcase %>
              <% when 'instagram' %>
              <path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2z"/>
              <% when 'linkedin' %>
              <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
              <% when 'dribbble' %>
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10c5.51 0 10-4.48 10-10S17.51 2 12 2zm6.605 4.61a8.502 8.502 0 0 1 1.93 5.314c-.281-.054-3.101-.629-5.943-.271-.065-.141-.12-.293-.184-.445a25.416 25.416 0 0 0-.564-1.236c3.145-1.28 4.577-3.124 4.761-3.362zM12 3.475c2.17 0 4.154.813 5.662 2.148-.152.216-1.443 1.941-4.48 3.08-1.399-2.57-2.95-4.675-3.189-5A8.687 8.687 0 0 1 12 3.475zm-3.633.803a53.896 53.896 0 0 1 3.167 4.935c-3.992 1.063-7.517 1.04-7.896 1.04a8.581 8.581 0 0 1 4.729-5.975zM3.453 12.01v-.26c.37.01 4.512.065 8.775-1.215.25.477.477.965.694 1.453-.109.033-.228.065-.336.098-4.404 1.42-6.753 5.97-6.735 6.5a5.873 5.873 0 0 1-2.354-4.597zM12 20.547a8.473 8.473 0 0 1-5.239-1.8c.152-.315 1.888-3.656 6.703-5.337.022-.01.033-.01.044-.017a28.247 28.247 0 0 1 1.821 3.207 8.4 8.4 0 0 1-3.296.616z"/>
              <% when 'behance' %>
              <path d="M22 7h-7v-2h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 3.211 3.483 3.312 4.588 2.029h3.168zm-7.686-4h4.965c-.105-1.547-1.136-2.219-2.477-2.219-1.466 0-2.277.768-2.488 2.219zm-9.574 6.988H0V5.211h9.954v5.188H3.997v-.001zM9.422 8.209H6.1v3.973h3.322c1.951 0 2.735-1.32 2.735-1.977 0-1.001-1.005-1.996-2.713-1.996zm-3.322 5.978h3.322v-3.973H6.1v3.973z"/>
              <% else %>
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/>
              <% end %>
            </svg>
            <a href="<%= link['url'] %>" target="_blank"><%= link['platform'] %></a>
          </li>
          <% end %>
        </ul>

        <!-- Megaphone illustration -->
        <img src="/assets/images/megaphone.png" alt="Megaphone" class="megaphone-img">
      </div>

      <!-- Right: Contact Form (Clipboard) -->
      <div class="contact-form-wrapper">
        <div class="clip-wrapper">
          <img src="/assets/images/clipboard.svg" alt="Clipboard Clip" class="clipboard-clip">
        </div>
        <div class="form-container">
          <form action="#" method="post">
            <div class="form-group">
              <label for="contact-name">Nama</label>
              <input type="text" id="contact-name" placeholder="Nama Anda" required>
            </div>
            <div class="form-group">
              <label for="contact-email">Email</label>
              <input type="email" id="contact-email" placeholder="Email Anda" required>
            </div>
            <div class="form-group">
              <label for="contact-project">Pilih Jenis Project</label>
              <select id="contact-project">
                <option value="">Pilih jenis project</option>
                <option value="web-design">Web Design</option>
                <option value="mobile-app">Mobile App</option>
                <option value="branding">Branding</option>
                <option value="ui-ux">UI/UX Design</option>
              </select>
            </div>
            <div class="form-group">
              <label for="contact-message">Pesan</label>
              <textarea id="contact-message" rows="3" placeholder="Tulis pesan Anda..." required></textarea>
            </div>
            <button type="submit" class="submit-btn">Kirim Pesan</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ====== FOOTER ====== -->
<footer class="footer">
  <div class="footer-container">
    <a href="/#beranda" class="footer-link">© 2025 <%= profile['name'] || 'Nurul DWI' %>. All rights reserved.</a>
    <p class="footer-love">Made with ❤️</p>
  </div>
</footer>