# Ignore environment files
.env
.env.local
.env.*.local

# Ignore log files and tmp directories
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep

# Ignore storage (except uploads)
/storage/*
!/storage/.keep
/storage/development/*
!/storage/development/.keep

# Ignore asset build files
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore node modules
node_modules/

# Ignore bundler config
/vendor/bundle/

# Ignore IDE files
.idea/
.vscode/
*.swp
*.swo

# Ignore system files
.DS_Store
Thumbs.db

# Ignore bootsnap cache
/tmp/cache/bootsnap/
